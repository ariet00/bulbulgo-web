{
  "name": "@doska/monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@doska/web",
    "dev:threeds": "turbo dev --filter=@doska/threeds",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.9",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.2.2",
    "turbo": "^2.0.0",
    "typescript": "^5"
  }
}